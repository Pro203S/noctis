{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "rootDir": "./src",
    "types": ["node"],
    "declaration": true,
    "removeComments": false,

    "outDir": "./dist"
  },
  "exclude": ["./tests/**/*", "./dist/**/*"]
}
